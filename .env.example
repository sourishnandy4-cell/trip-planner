# ─── Supabase Configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in your project values.
# Leave blank to run in offline mock mode (no Supabase account needed).
#
# How to get these values:
#   1. Create a free project at https://supabase.com
#   2. Go to Project → Settings → API
#   3. Copy "Project URL" and "anon / public" key
#   4. Run the SQL in database/schema.sql then database/seed.sql
#
# For GitHub Pages deployment, add these as repository secrets:
#   GitHub → Settings → Secrets and variables → Actions
# ──────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://<your-20-char-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
